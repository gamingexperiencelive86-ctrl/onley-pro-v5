datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model License {
  id        String   @id @default(cuid())
  guildId   String   @unique
  active    Boolean  @default(true)
  expiresAt DateTime

  @@map("license")
}

model TimeLog {
  id             Int       @id @default(autoincrement())
  userId         String
  username       String
  guildId        String
  startTime      DateTime  @default(now())
  endTime        DateTime?
  pauseStart     DateTime?
  totalPauseMin  Int       @default(0)
  totalWorkMin   Int       @default(0)
  status         String    @default("LAVORO")

  @@map("timelog")
}
